{
    "name": "captionit",
    "version": "0.0.1",
    "type": "module",
    "private": true,
    "scripts": {
        "check": "bunx --bun biome check --write",
        "format": "bunx --bun biome format --write",
        "lint": "bun run scripts/lint.ts",
        "backend:test": "cd apps/backend && bun test",
        "backend:dev": "cd apps/backend && bun run dev",
        "backend:start": "cd apps/backend && bun run start",
        "backend:typecheck": "cd apps/backend && bun run typecheck",
        "backend:openapi:generate": "cd apps/backend && bun run openapi-types:generate:to-frontend",
        "backend:ws-types:generate": "cd apps/backend && bun run ws-types:generate:to-frontend",
        "frontend:dev": "cd apps/frontend && bun run dev",
        "frontend:build": "cd apps/frontend && bun run build",
        "frontend:preview": "cd apps/frontend && bun run preview",
        "frontend:typecheck": "cd apps/frontend && bun run typecheck",
        "result:test": "cd packages/result && bun test",
        "result:typecheck": "cd packages/result && bun run typecheck",
        "server:test": "cd packages/server && bun test",
        "server:typecheck": "cd packages/server && bun run typecheck"
    },
    "workspaces": {
        "packages": [
            "apps/*",
            "packages/*"
        ],
        "catalog": {
            "@types/bun": "latest",
            "@types/node": "^24.10.1",
            "@types/react": "^19.2.0",
            "@types/react-dom": "^19.2.0",
            "typescript": "^5",
            "vite": "npm:rolldown-vite@7.2.5",
            "zod": "^4.1.11",
            "zod-openapi": "^5.4.5",
            "react": "^19.2.0",
            "react-dom": "^19.2.0",
            "@vitejs/plugin-react": "^5.0.4",
            "tailwindcss": "^4.1.18",
            "@tailwindcss/vite": "^4.1.18",
            "jose": "^6.1.3",
            "openapi-fetch": "^0.15.0",
            "concurrently": "^9.2.1"
        }
    },
    "devDependencies": {
        "@biomejs/biome": "2.3.10",
        "@types/bun": "^1.3.6",
        "@types/node": "^24.10.9",
        "typescript": "^5.9.3"
    },
    "description": "CaptionIt - Local-first image captioning app using OpenAI-compatible model backends.",
    "keywords": [
        "bun",
        "captioning",
        "image-captioning",
        "local-first",
        "openai-compatible",
        "ollama",
        "typescript",
        "react",
        "tailwindcss",
        "sse",
        "streaming"
    ],
    "engines": {
        "bun": ">=1.3.3"
    }
}
