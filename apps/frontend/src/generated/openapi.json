                },
                "schema": {
                  "$ref": "#/components/schemas/InternalServerErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/captioning/caption": {
      "put": {
        "operationId": "saveCaption",
        "summary": "Save caption",
        "description": "Overwrite the caption .txt file for an image",
        "tags": [
          "Captioning"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SaveCaptionBody"
              }
            }
          }
        },
        "responses": {
          "400": {
            "description": "Bad Request - Invalid input or validation failed",
            "content": {
              "application/json": {
                "example": {
                  "message": "Validation failed",
                  "code": "BAD_REQUEST",
                  "details": [
                    {
                      "path": [
                        "email"
                      ],
                      "message": "Invalid email format"
                    }
                  ]
                },
                "schema": {
                  "$ref": "#/components/schemas/BadRequestErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error - Unexpected server error",
            "content": {
              "application/json": {
                "example": {
                  "message": "Internal server error",
                  "code": "INTERNAL_ERROR",
                  "details": "Stack trace or error details for debugging"
                },
                "schema": {
                  "$ref": "#/components/schemas/InternalServerErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/captioning/start": {
      "post": {
        "operationId": "startCaptioning",
        "summary": "Start captioning session",
        "description": "Validates the directory, scans for images, and starts a background captioning session. Returns a sessionId.",
        "tags": [
          "Captioning"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "200 response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StartResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Invalid input or validation failed",
            "content": {
              "application/json": {
                "example": {
                  "message": "Validation failed",
                  "code": "BAD_REQUEST",
                  "details": [
                    {
                      "path": [
                        "email"
                      ],
                      "message": "Invalid email format"
                    }
                  ]
                },
                "schema": {
                  "$ref": "#/components/schemas/BadRequestErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error - Unexpected server error",
            "content": {
              "application/json": {
                "example": {
                  "message": "Internal server error",
                  "code": "INTERNAL_ERROR",
                  "details": "Stack trace or error details for debugging"
                },
                "schema": {
                  "$ref": "#/components/schemas/InternalServerErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/captioning/session": {
      "get": {
        "operationId": "getCaptioningSession",
        "summary": "Get captioning session status",
        "description": "Returns the status and progress of a captioning session",
        "tags": [
          "Captioning"
        ],
        "responses": {
          "200": {
            "description": "200 response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionState"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error - Unexpected server error",
            "content": {
              "application/json": {
                "example": {
                  "message": "Internal server error",
                  "code": "INTERNAL_ERROR",
                  "details": "Stack trace or error details for debugging"
                },
                "schema": {
                  "$ref": "#/components/schemas/InternalServerErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/captioning/stop": {
      "post": {
        "operationId": "stopCaptioning",
        "summary": "Stop captioning session",
        "description": "Signals a running captioning session to stop after the current image",
        "tags": [
          "Captioning"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StopBody"
              }
            }
          }
        },
        "responses": {
          "400": {
            "description": "Bad Request - Invalid input or validation failed",
            "content": {
              "application/json": {
                "example": {
                  "message": "Validation failed",
                  "code": "BAD_REQUEST",
                  "details": [
                    {
                      "path": [
                        "email"
                      ],
                      "message": "Invalid email format"
                    }
                  ]
                },
                "schema": {
                  "$ref": "#/components/schemas/BadRequestErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error - Unexpected server error",
            "content": {
              "application/json": {
                "example": {
                  "message": "Internal server error",
                  "code": "INTERNAL_ERROR",
                  "details": "Stack trace or error details for debugging"
                },
                "schema": {
                  "$ref": "#/components/schemas/InternalServerErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/redirect-internal": {
      "get": {
        "operationId": "redirectInternal",
        "summary": "Internal Redirect",
        "description": "Demonstrates type-safe internal redirect to another route in the application",
        "tags": [
          "System"
        ],
        "responses": {
          "500": {
            "description": "Internal Server Error - Unexpected server error",
            "content": {
              "application/json": {
                "example": {
                  "message": "Internal server error",
                  "code": "INTERNAL_ERROR",
                  "details": "Stack trace or error details for debugging"
                },
                "schema": {
                  "$ref": "#/components/schemas/InternalServerErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/redirect-to-health": {
      "get": {
        "operationId": "redirectToHealth",
        "summary": "Internal Redirect to Health",
        "description": "Demonstrates type-safe internal redirect to another route in the application",
        "tags": [
          "System"
        ],
        "responses": {
          "500": {
            "description": "Internal Server Error - Unexpected server error",
            "content": {
              "application/json": {
                "example": {
                  "message": "Internal server error",
                  "code": "INTERNAL_ERROR",
                  "details": "Stack trace or error details for debugging"
                },
                "schema": {
                  "$ref": "#/components/schemas/InternalServerErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/redirect-external": {
      "get": {
        "operationId": "redirectExternal",
        "summary": "External Redirect",
        "description": "Demonstrates redirect to an external URL",
        "tags": [
          "System"
        ],
        "responses": {
          "500": {
            "description": "Internal Server Error - Unexpected server error",
            "content": {
              "application/json": {
                "example": {
                  "message": "Internal server error",
                  "code": "INTERNAL_ERROR",
                  "details": "Stack trace or error details for debugging"
                },
                "schema": {
                  "$ref": "#/components/schemas/InternalServerErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ScanBody": {
        "type": "object",
        "properties": {
          "dirPath": {
            "type": "string",
            "minLength": 1,
            "example": "/home/user/dataset"
          },
          "filesFilter": {
            "example": [
              "photo01.jpg",
              "photo02.png"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "dirPath"
        ],
        "title": "Scan Request Body"
      },
      "SaveCaptionBody": {
        "type": "object",
        "properties": {
          "imagePath": {
            "type": "string",
            "minLength": 1,
            "example": "/home/user/dataset/photo01.jpg"
          },
          "caption": {
            "type": "string"
          }
        },
        "required": [
          "imagePath",
          "caption"
        ],
        "title": "Save Caption Body"
      },
      "StartBody": {
        "type": "object",
        "properties": {
          "dirPath": {
            "type": "string",
            "minLength": 1,
            "example": "/home/user/dataset"
          },
          "mode": {
            "default": "store",
            "example": "store",
            "type": "string",
            "enum": [
              "store",
              "append",
              "replace"
            ]
          },
          "filesFilter": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "serviceHost": {
            "type": "string"
          },
          "apiKey": {
            "type": "string"
          },
          "modelName": {
            "type": "string"
          },
          "instruction": {
            "type": "string"
          },
          "maxResolution": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "sessionId": {
            "type": "string",
            "description": "Client-generated session ID (UUID)"
          }
        },
        "required": [
          "dirPath",
          "sessionId"
        ],
        "title": "Start Captioning Body"
      },
      "StopBody": {
        "type": "object",
        "properties": {
          "sessionId": {
            "type": "string"
          }
        },
        "required": [
          "sessionId"
        ],
        "title": "Stop Request Body"
      },
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "const": "ok",
            "example": "ok"
          },
          "timestamp": {
            "type": "string",
            "example": "2026-06-27T05:34:34.855Z"
          },
          "uptime": {
            "type": "number",
            "example": 123.456
          }
        },
        "required": [
          "status",
          "timestamp",
          "uptime"
        ],
        "additionalProperties": false,
        "title": "Health Check Response",
        "description": "Health check response indicating service status"
      },
      "ScanResponse": {
        "type": "object",
        "properties": {
          "dirPath": {
            "type": "string"
          },
          "images": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ImageFile"
            }
          },
          "total": {
            "type": "number"
          }
        },
        "required": [
          "dirPath",
          "images",
          "total"
        ],
        "additionalProperties": false,
        "title": "Scan Response"
      },
      "ImageFile": {
        "type": "object",
        "properties": {
          "file": {
            "type": "string",
            "example": "photo01.jpg"
          },
          "hasCaption": {
            "type": "boolean",
            "example": true
          },
          "caption": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "example": "A woman standing..."
          },
          "sizeMB": {
            "type": "string",
            "example": "1.24"
          }
        },
        "required": [
          "file",
          "hasCaption",
          "caption",
          "sizeMB"
        ],
        "additionalProperties": false,
        "title": "Image File"
      },
      "ConfigResponse": {
        "type": "object",
        "properties": {
          "serviceHost": {
            "type": "string"
          },
          "apiKey": {
            "type": "string"
          },
          "modelName": {
            "type": "string"
          },
          "instruction": {
            "type": "string"
          },
          "maxResolution": {
            "type": "number"
          }
        },
        "required": [
          "serviceHost",
          "apiKey",
          "modelName",
          "instruction",
          "maxResolution"
        ],
        "additionalProperties": false,
        "title": "Captioning Config"
      },
      "StartResponse": {
        "type": "object",
        "properties": {
          "sessionId": {
            "type": "string"
          }
        },
        "required": [
          "sessionId"
        ],
        "additionalProperties": false,
        "title": "Start Captioning Response"
      },
      "SessionState": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "running",
              "done",
              "stopped"
            ]
          },
          "total": {
            "type": "number"
          },
          "captioned": {
            "type": "number"
          },
          "skipped": {
            "type": "number"
          },
          "failed": {
            "type": "number"
          }
        },
        "required": [
          "id",
          "status",
          "total",
          "captioned",
          "skipped",
          "failed"
        ],
        "additionalProperties": false,
        "title": "Session State"
      },
      "BadRequestErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "string",
            "const": "BAD_REQUEST"
          },
          "details": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field": {
                  "type": "string",
                  "description": "Field with validation error"
                },
                "message": {
                  "type": "string",
                  "description": "Validation error message"
                }
              },
              "required": [
                "field",
                "message"
              ],
              "additionalProperties": false
            },
            "description": "List of validation errors"
          }
        },
        "required": [
          "message",
          "code",
          "details"
        ],
        "additionalProperties": false,
        "description": "Bad Request Error Response"
      },
      "InternalServerErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "string",
            "const": "INTERNAL_ERROR"
          },
          "details": {
            "description": "Internal error details (for debugging)",
            "type": "string"
          }
        },
        "required": [
          "message",
          "code"
        ],
        "additionalProperties": false,
        "description": "Internal Server Error Response"
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "string",
            "description": "Error code"
          },
          "details": {
            "description": "Additional error details"
          }
        },
        "required": [
          "message",
          "code"
        ],
        "additionalProperties": false
      },
      "UnauthorizedErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "string",
            "const": "UNAUTHORIZED"
          },
          "details": {
            "description": "Additional error details"
          }
        },
        "required": [
          "message",
          "code"
        ],
        "additionalProperties": false,
        "description": "Unauthorized Error Response"
      },
      "ForbiddenErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "string",
            "const": "FORBIDDEN"
          },
          "details": {
            "description": "Additional error details"
          }
        },
        "required": [
          "message",
          "code"
        ],
        "additionalProperties": false,
        "description": "Forbidden Error Response"
      },
      "NotFoundErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "string",
            "const": "NOT_FOUND"
          },
          "details": {
            "description": "Additional error details"
          }
        },
        "required": [
          "message",
          "code"
        ],
        "additionalProperties": false,
        "description": "Not Found Error Response"
      },
      "ConflictErrorResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "string",
            "const": "CONFLICT"
          },
          "details": {
            "description": "Conflict details",
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "properties": {},
                "additionalProperties": false
              }
            ]
          }
        },
        "required": [
          "message",
          "code"
        ],
        "additionalProperties": false,
        "description": "Conflict Error Response"
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT authorization token"
      },
