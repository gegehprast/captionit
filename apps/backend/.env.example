# Server Configuration
APP_NAME=CaptionIt
APP_URL=http://localhost:3001

NODE_ENV=development
PORT=3001
HOST=localhost

# HTTP Server Settings
# Maximum Request Body Size (in bytes)
HTTP_MAX_REQUEST_BODY_SIZE=10485760

# CORS
# Use comma-separated list for multiple origins
CORS_ORIGIN="http://127.0.0.1:3001,http://localhost:3001,http://localhost:5173,http://localhost:4173,http://localhost:3000"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
# Options: none, error, warn, info, debug, trace
LOG_LEVEL=info
LOG_DISABLED_COMPONENTS=

# Graceful Shutdown
SHUTDOWN_TIMEOUT_MS=10000

# Captioning Service Configuration
DEFAULT_SERVICE_HOST=http://localhost:11434/v1
DEFAULT_SERVICE_API_KEY=
DEFAULT_MODEL_NAME=qwen3-vl:4b-instruct
DEFAULT_INSTRUCTION=`You are an expert AI image captioner preparing a dataset for a Character LoRA. Your goal is to describe the mutable elements of the image while completely ignoring the permanent physical traits of the main subject. Please write a concise, natural language paragraph describing this image.`
DEFAULT_MAX_RESOLUTION=1024
