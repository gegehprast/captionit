# Server Configuration
APP_NAME=Bunkit
APP_URL=https://bunkit.dev

NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# HTTP Server Settings
# Maximum Request Body Size (in bytes)
HTTP_MAX_REQUEST_BODY_SIZE=10485760

# CORS
# Use comma-separated list for multiple origins
# Example: http://localhost:3000,https://example.com
CORS_ORIGIN="http://127.0.0.1:3001,http://localhost:3001,http://localhost:5173,http://localhost:4173,http://localhost:3000"

# Database
DATABASE_URL=postgresql://localhost:5432/bunkit

# JWT Authentication
# Generate secure secrets with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-please-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-please-change-this-in-production
JWT_REFRESH_EXPIRES_IN=30d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
# Options: none, error, warn, info, debug, trace
LOG_LEVEL=debug
LOG_DISABLED_COMPONENTS=

# Graceful Shutdown
SHUTDOWN_TIMEOUT_MS=10000

# Captioning Service Configuration
DEFAULT_SERVICE_HOST=http://localhost:11434/v1
DEFAULT_SERVICE_API_KEY=
DEFAULT_MODEL_NAME=huihui_ai/qwen3-vl-abliterated:4b-instruct
